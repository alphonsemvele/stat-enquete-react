models:
    User: { nom: 'string:100', prenom: 'string:100', email: 'string:150 unique', email_verified_at: 'timestamp nullable', password: string, telephone: 'string:20 nullable', avatar: 'string nullable', matricule: 'string:20 unique nullable', fonction: 'enum:medecin,infirmier,sage_femme,pharmacien,technicien,laborantin,administratif,receptionniste,comptable nullable', specialite: 'string:100 nullable', service_id: 'id foreign:services nullable', date_embauche: 'date nullable', statut: 'enum:actif,inactif,conge,suspendu default:actif', remember_token: 'string:100 nullable', timestamps: timestamps, softdeletes: softDeletes, relationships: { belongsTo: Service, hasMany: 'Consultation, Prescription, Pointage, DemandeConge' } }
    Role: { nom: 'string:50 unique', description: 'text nullable', couleur: 'string:20 nullable', timestamps: timestamps, relationships: { belongsToMany: 'User, Permission' } }
    Permission: { nom: 'string:100 unique', description: 'text nullable', module: 'string:50', timestamps: timestamps, relationships: { belongsToMany: Role } }
    Service: { code: 'string:20 unique', nom: 'string:100', description: 'text nullable', chef_service_id: 'id foreign:users nullable', etage: 'string:10 nullable', batiment: 'string:50 nullable', telephone: 'string:20 nullable', email: 'string:100 nullable', capacite_lits: 'integer unsigned default:0', actif: 'boolean default:true', timestamps: timestamps, softdeletes: softDeletes, relationships: { hasMany: 'User, Lit, Patient, Admission', belongsTo: 'User:chef_service' } }
    Lit: { numero: 'string:20', service_id: 'id foreign:services', chambre: 'string:20 nullable', type: 'enum:standard,soins_intensifs,reanimation,pediatrique,maternite default:standard', statut: 'enum:libre,occupe,maintenance,reserve default:libre', equipements: 'json nullable', tarif_journalier: 'decimal:10,2 default:0', timestamps: timestamps, softdeletes: softDeletes, relationships: { belongsTo: Service, hasMany: Admission } }
    Patient: { numero_dossier: 'string:20 unique', nom: 'string:100', prenom: 'string:100', date_naissance: date, sexe: 'enum:M,F', lieu_naissance: 'string:100 nullable', nationalite: 'string:50 default:Camerounaise', cni: 'string:30 nullable unique', telephone: 'string:20 nullable', telephone_urgence: 'string:20 nullable', email: 'string:100 nullable', adresse: 'text nullable', ville: 'string:50 nullable', quartier: 'string:100 nullable', profession: 'string:100 nullable', situation_matrimoniale: 'enum:celibataire,marie,divorce,veuf nullable', groupe_sanguin: 'enum:A+,A-,B+,B-,AB+,AB-,O+,O- nullable', allergies: 'json nullable', antecedents_medicaux: 'json nullable', antecedents_chirurgicaux: 'json nullable', antecedents_familiaux: 'json nullable', assurance_id: 'id foreign:assurances nullable', numero_assurance: 'string:50 nullable', personne_contact_nom: 'string:100 nullable', personne_contact_telephone: 'string:20 nullable', personne_contact_lien: 'string:50 nullable', photo: 'string nullable', notes: 'text nullable', statut: 'enum:actif,inactif,decede default:actif', timestamps: timestamps, softdeletes: softDeletes, relationships: { belongsTo: Assurance, hasMany: 'Admission, Consultation, Prescription, RendezVous, Facture, AnalyseLaboratoire, ExamenImagerie, ConstanteVitale, PatientHad' } }
    Assurance: { code: 'string:20 unique', nom: 'string:100', type: 'enum:publique,privee,mutuelle', adresse: 'text nullable', telephone: 'string:20 nullable', email: 'string:100 nullable', taux_couverture: 'decimal:5,2 default:0', plafond_annuel: 'decimal:12,2 nullable', delai_paiement: 'integer unsigned default:30', contact_nom: 'string:100 nullable', contact_telephone: 'string:20 nullable', actif: 'boolean default:true', timestamps: timestamps, softdeletes: softDeletes, relationships: { hasMany: 'Patient, Facture' } }
    Admission: { numero: 'string:20 unique', patient_id: 'id foreign:patients', service_id: 'id foreign:services', lit_id: 'id foreign:lits nullable', medecin_id: 'id foreign:users', type: 'enum:urgence,programmee,transfert default:programmee', motif: text, diagnostic_entree: 'text nullable', diagnostic_sortie: 'text nullable', date_admission: datetime, date_sortie: 'datetime nullable', mode_sortie: 'enum:guerison,amelioration,transfert,evasion,deces,contre_avis nullable', accompagnant_nom: 'string:100 nullable', accompagnant_telephone: 'string:20 nullable', accompagnant_lien: 'string:50 nullable', notes: 'text nullable', statut: 'enum:en_cours,termine,annule default:en_cours', timestamps: timestamps, softdeletes: softDeletes, relationships: { belongsTo: 'Patient, Service, Lit, User:medecin', hasMany: 'Consultation, Prescription, ConstanteVitale, ActeMedical' } }
    RendezVous: { patient_id: 'id foreign:patients', medecin_id: 'id foreign:users', service_id: 'id foreign:services nullable', date_heure: datetime, duree_minutes: 'integer unsigned default:30', type: 'enum:consultation,suivi,examen,chirurgie,vaccination default:consultation', motif: 'text nullable', notes: 'text nullable', statut: 'enum:planifie,confirme,en_attente,en_cours,termine,annule,absent default:planifie', timestamps: timestamps, relationships: { belongsTo: 'Patient, User:medecin, Service', hasOne: Consultation } }
    Consultation: { numero: 'string:20 unique', patient_id: 'id foreign:patients', medecin_id: 'id foreign:users', admission_id: 'id foreign:admissions nullable', rendez_vous_id: 'id foreign:rendez_vous nullable', service_id: 'id foreign:services nullable', date_consultation: datetime, motif: text, histoire_maladie: 'text nullable', examen_clinique: 'text nullable', hypotheses_diagnostiques: 'json nullable', diagnostic_principal: 'string:255 nullable', diagnostics_secondaires: 'json nullable', conduite_a_tenir: 'text nullable', recommandations: 'text nullable', prochain_rdv: 'date nullable', duree_minutes: 'integer unsigned nullable', statut: 'enum:en_cours,termine,annule default:en_cours', timestamps: timestamps, softdeletes: softDeletes, relationships: { belongsTo: 'Patient, User:medecin, Admission, RendezVous, Service', hasMany: 'Prescription, AnalyseLaboratoire, ExamenImagerie, ActeMedical' } }
    ConstanteVitale: { patient_id: 'id foreign:patients', admission_id: 'id foreign:admissions nullable', user_id: 'id foreign:users', date_mesure: datetime, poids: 'decimal:5,2 nullable', taille: 'decimal:5,2 nullable', temperature: 'decimal:4,2 nullable', tension_systolique: 'integer unsigned nullable', tension_diastolique: 'integer unsigned nullable', frequence_cardiaque: 'integer unsigned nullable', frequence_respiratoire: 'integer unsigned nullable', saturation_oxygene: 'integer unsigned nullable', glycemie: 'decimal:5,2 nullable', score_douleur: 'integer unsigned nullable', notes: 'text nullable', timestamps: timestamps, relationships: { belongsTo: 'Patient, Admission, User' } }
    ActeMedical: { code: 'string:20', libelle: 'string:255', consultation_id: 'id foreign:consultations nullable', admission_id: 'id foreign:admissions nullable', patient_id: 'id foreign:patients', medecin_id: 'id foreign:users', date_acte: datetime, description: 'text nullable', resultat: 'text nullable', quantite: 'integer unsigned default:1', prix_unitaire: 'decimal:10,2 default:0', prix_total: 'decimal:10,2 default:0', statut: 'enum:planifie,en_cours,termine,annule default:planifie', timestamps: timestamps, relationships: { belongsTo: 'Consultation, Admission, Patient, User:medecin' } }
    Medicament: { code: 'string:20 unique', nom: 'string:200', dci: 'string:200 nullable', forme: 'enum:comprime,gelule,sirop,injectable,pommade,collyre,suppositoire,solution,poudre,autre', dosage: 'string:50 nullable', categorie: 'enum:antalgique,antibiotique,anti_inflammatoire,antidiabetique,antihypertenseur,antipaludeen,antiseptique,vitamine,autre', voie_administration: 'enum:orale,injectable,cutanee,rectale,oculaire,nasale,auriculaire,autre default:orale', conditionnement: 'string:100 nullable', stock_actuel: 'integer unsigned default:0', stock_minimum: 'integer unsigned default:10', stock_maximum: 'integer unsigned default:1000', prix_achat: 'decimal:10,2 default:0', prix_vente: 'decimal:10,2 default:0', tva: 'decimal:5,2 default:0', fournisseur_id: 'id foreign:fournisseurs nullable', date_expiration: 'date nullable', emplacement: 'string:50 nullable', ordonnance_obligatoire: 'boolean default:false', actif: 'boolean default:true', notes: 'text nullable', timestamps: timestamps, softdeletes: softDeletes, relationships: { belongsTo: Fournisseur, hasMany: 'LignePrescription, MouvementStock, LigneCommande' } }
    Fournisseur: { code: 'string:20 unique', nom: 'string:150', type: 'enum:laboratoire,grossiste,importateur', adresse: 'text nullable', ville: 'string:50 nullable', pays: 'string:50 default:Cameroun', telephone: 'string:20 nullable', email: 'string:100 nullable', site_web: 'string:200 nullable', contact_nom: 'string:100 nullable', contact_telephone: 'string:20 nullable', delai_livraison_jours: 'integer unsigned default:7', conditions_paiement: 'text nullable', actif: 'boolean default:true', timestamps: timestamps, softdeletes: softDeletes, relationships: { hasMany: 'Medicament, CommandeFournisseur' } }
    Prescription: { numero: 'string:20 unique', patient_id: 'id foreign:patients', medecin_id: 'id foreign:users', consultation_id: 'id foreign:consultations nullable', admission_id: 'id foreign:admissions nullable', date_prescription: datetime, date_validite: 'date nullable', instructions_generales: 'text nullable', statut: 'enum:en_attente,partiellement_delivree,delivree,annulee default:en_attente', timestamps: timestamps, softdeletes: softDeletes, relationships: { belongsTo: 'Patient, User:medecin, Consultation, Admission', hasMany: 'LignePrescription, Delivrance' } }
    LignePrescription: { prescription_id: 'id foreign:prescriptions', medicament_id: 'id foreign:medicaments', posologie: 'string:255', quantite_prescrite: 'integer unsigned', quantite_delivree: 'integer unsigned default:0', duree_jours: 'integer unsigned nullable', voie_administration: 'string:50 nullable', instructions: 'text nullable', timestamps: timestamps, relationships: { belongsTo: 'Prescription, Medicament' } }
    Delivrance: { numero: 'string:20 unique', prescription_id: 'id foreign:prescriptions', pharmacien_id: 'id foreign:users', date_delivrance: datetime, montant_total: 'decimal:10,2 default:0', montant_paye: 'decimal:10,2 default:0', mode_paiement: 'enum:especes,carte,mobile_money,assurance,credit nullable', notes: 'text nullable', statut: 'enum:en_cours,terminee,annulee default:en_cours', timestamps: timestamps, relationships: { belongsTo: 'Prescription, User:pharmacien', hasMany: LigneDelivrance } }
